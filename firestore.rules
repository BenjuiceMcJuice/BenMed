rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Access control document — any authenticated user can read (needed to check if they're authorized).
    // First create: anyone authenticated can create if they set themselves as admin.
    // Updates: only the current admin can modify.
    match /family/access {
      allow read: if request.auth != null;
      allow create: if request.auth != null
        && request.resource.data.adminUid == request.auth.uid;
      allow update, delete: if request.auth != null
        && resource.data.adminUid == request.auth.uid;
    }

    // Invite codes — admin-only read/write.
    match /family/invites {
      allow read, write: if request.auth != null
        && exists(/databases/$(database)/documents/family/access)
        && request.auth.uid == get(/databases/$(database)/documents/family/access).data.adminUid;
    }

    // Access requests — any authenticated user can create/read their own pending doc;
    // only admin can read all and delete.
    match /family/requests/pending/{uid} {
      allow create: if request.auth != null && request.auth.uid == uid;
      allow read: if request.auth != null
        && (request.auth.uid == uid
            || (exists(/databases/$(database)/documents/family/access)
                && request.auth.uid == get(/databases/$(database)/documents/family/access).data.adminUid));
      allow delete: if request.auth != null
        && exists(/databases/$(database)/documents/family/access)
        && request.auth.uid == get(/databases/$(database)/documents/family/access).data.adminUid;
    }

    // Main family data — authorized users only.
    match /family/main {
      allow read, write: if request.auth != null
        && exists(/databases/$(database)/documents/family/access)
        && request.auth.uid in get(/databases/$(database)/documents/family/access).data.authorizedUids;
    }

    // Legacy patient data — kept for migration period.
    match /patients/{patientId} {
      allow read, write: if request.auth != null
        && request.auth.uid in ['Cg9SdWI8o1QdMAL7YkmxKTFkYcM2', 'qbfqkYu8VCbRRTqBNjZtATwPFkY2'];
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
